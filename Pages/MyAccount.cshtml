@page
@model BeautyClinic.Pages.MyAccountModel
@{
    if (Model == null || Model.User == null)
    {
        ViewData["Title"] = "Błąd - Brak danych modelu";
    }
    else
    {
        ViewData["Title"] = "Moje konto";
    }
}

@Html.AntiForgeryToken()

<div class="my-account-container">
    <header class="custom-header">
        <div class="navbar">
            <div class="nav-item center" style="font-family:'Montserrat-Light'">
                <a class="nav-link" asp-page="/CustomerView">
                    <img src="~/images/logo.png" alt="BEAUTY CLINIC" class="nav-logo">
                </a>
            </div>
            <div class="nav-item right">
                <div>
                    <a class="nav-link" asp-page="/ServiceList">
                        <img src="~/images/calendar2.png" alt="Twój kalendarz" class="nav-calendar">
                    </a>
                </div>
                <div class="dropdown">
                    <span style="cursor: pointer;">
                        <img src="~/images/user.png" alt="Moje wizyty" class="nav-icon">
                    </span>
                    <div class="dropdown-menu">
                        <a class="sign my-account" href="/MyAccount">Moje konto</a>
                        <a class="sign sign-out" href="/Logout">Wyloguj</a>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <div class="my-account-content">
        <div class="sidebar">
            <ul class="menu-list">
                <li class="menu-item"><a href="#dashboard">Panel</a></li>
                <li class="menu-item"><a href="#profile">Profil</a></li>
                <li class="menu-item"><a href="#appointments">Wizyty</a></li>
                <li class="menu-item"><a href="#history">Historia</a></li>
                <li class="menu-item"><a href="/Logout">Wyloguj się</a></li>
            </ul>
        </div>
        <div class="dashboard">
            <div class="section-content" id="dashboard">
                <h2 class="welcome-title">Witaj, @(Model?.User?.FirstName ?? "Użytkowniku")!</h2>
                <div class="widget-grid">
                    <a href="#profile">
                        <div class="widget">
                            <img src="~/images/my-account.png" alt="Profil" class="widget-icon profile">
                            <div class="widget-label">Profil</div>
                        </div>
                    </a>
                    <a href="#reset-password">
                        <div class="widget">
                            <img src="~/images/reset-password.png" alt="Zmień hasło" class="widget-icon change-password">
                            <div class="widget-label">Zmień hasło</div>
                        </div>
                    </a>
                    <a href="#appointments">
                        <div class="widget">
                            <img src="~/images/calendar.png" alt="Wizyty" class="widget-icon appointment">
                            <div class="widget-label">Wizyty</div>
                        </div>
                    </a>
                    <a href="#history">
                        <div class="widget">
                            <img src="~/images/history.png" alt="Historia" class="widget-icon history">
                            <div class="widget-label">Historia</div>
                        </div>
                    </a>
                    <a href="/DeleteAccount">
                        <div class="widget">
                            <img src="~/images/user-deleted.png" alt="Usuń konto" class="widget-icon delete">
                            <div class="widget-label">Usuń konto</div>
                        </div>
                    </a>
                    <a href="/Logout">
                        <div class="widget">
                            <img src="~/images/logout.png" alt="Wyloguj się" class="widget-icon sign-out">
                            <div class="widget-label">Wyloguj się</div>
                        </div>
                    </a>
                </div>
            </div>
            <div class="section-content" id="profile" style="display: none;">
                <div class="profile-container">
                    <h2 class="profile-welcome-title">Witaj, @(Model?.User?.FirstName ?? "Użytkowniku")!</h2>
                    <div class="profile-content">
                        <form id="profile-form" method="post" asp-page-handler="UpdateProfile">
                            @Html.AntiForgeryToken()
                            <div class="profile-item">
                                <label asp-for="Profile.FirstName">Imię:</label>
                                <input asp-for="Profile.FirstName" class="profile-value edit-input" value="@(Model?.Profile?.FirstName ?? "")" readonly required />
                                <span asp-validation-for="Profile.FirstName" class="text-danger"></span>
                            </div>
                            <div class="profile-item">
                                <label asp-for="Profile.LastName">Nazwisko:</label>
                                <input asp-for="Profile.LastName" class="profile-value edit-input" value="@(Model?.Profile?.LastName ?? "")" readonly required />
                                <span asp-validation-for="Profile.LastName" class="text-danger"></span>
                            </div>
                            <div class="profile-item">
                                <label asp-for="Profile.PhoneNumber">Telefon:</label>
                                <input asp-for="Profile.PhoneNumber" class="profile-value edit-input" value="@(Model?.Profile?.PhoneNumber ?? "")" readonly required />
                                <span asp-validation-for="Profile.PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="profile-item">
                                <label asp-for="Profile.Email">Email:</label>
                                <input asp-for="Profile.Email" class="profile-value edit-input" type="email" value="@(Model?.Profile?.Email ?? "")" readonly required />
                                <span asp-validation-for="Profile.Email" class="text-danger"></span>
                            </div>
                            <button type="button" id="cancel-changes-profile-btn" class="cancel-button" style="display: none;">Anuluj</button>
                            <button type="button" id="edit-profile-btn" class="edit-button">Edytuj</button>
                            <button type="submit" id="save-profile-btn" class="save-button" style="display: none;">Zapisz</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="section-content" id="reset-password" style="display: none;">
                <div class="password-reset-container">
                    <h3>ZMIEŃ HASŁO</h3>
                    <div class="password-reset-content">
                        <form id="password-reset-form" method="post" asp-page-handler="UpdatePassword">
                            @Html.AntiForgeryToken()
                            <div class="password-item">
                                <label for="Input_Username" class="visually-hidden">Nazwa użytkownika</label>
                                <input type="hidden" id="Input_Username" asp-for="Input.Username" value="@(Model?.Input?.Username ?? Model?.User?.Email ?? "unknown_user")" autocomplete="username" aria-label="Nazwa użytkownika" />
                            </div>
                            <div class="password-item">
                                <label for="Input_OldPassword">Stare hasło:</label>
                                <input id="Input_OldPassword" asp-for="Input.OldPassword" class="password-value edit-input" type="password" required autocomplete="current-password">
                                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                            </div>
                            <div class="password-item">
                                <label for="Input_NewPassword">Nowe hasło:</label>
                                <input id="Input_NewPassword" asp-for="Input.NewPassword" class="password-value edit-input" type="password" required autocomplete="new-password">
                                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                            </div>
                            <div class="password-item">
                                <label for="Input_ConfirmNewPassword">Potwierdź hasło:</label>
                                <input id="Input_ConfirmNewPassword" asp-for="Input.ConfirmNewPassword" class="password-value edit-input" type="password" required autocomplete="new-password">
                                <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
                            </div>
                            <button type="submit" id="save-password-btn" class="save-button password-save-button">Zatzdwierdź zmiany</button>
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="section-content" id="appointments" style="display: none;">
                <div class="view-toggle" id="toggle">
                    <p class="toggle-title">WIDOK</p>
                    <button class="toggle-button active" id="calendar-toggle">
                        <p>1</p>
                    </button>
                    <button class="toggle-button" id="list-toggle">
                        <p>2</p>
                    </button>
                </div>
                <div class="calendar-container" id="calendar-view">
                    <div class="calendar-base">
                        <div class="calendar-left">
                            <div class="num-date" id="calendar-date">12</div>
                            <div class="day" id="calendar-day">Aug</div>
                            <div class="current-events">WIZYTY</div>
                            <div class="event-line"></div>
                            <div class="appointments-list" id="appointments-list"></div>
                            <div class="event-line"></div>
                            <button class="add-event" id="add-event">+</button>
                        </div>
                        <div class="calendar-right">
                            <div class="year-nav">
                                <span class="nav-arrow" id="prev-year">←</span>
                                <span class="year-display" id="year-display">2025</span>
                                <span class="nav-arrow" id="next-year">→</span>
                            </div>
                            <div class="months-row" id="months-row"></div>
                            <div class="calendar-grid" id="calendar-grid"></div>
                        </div>
                    </div>
                </div>
                <div class="appointments-list-container" id="list-view" style="display: none;">
                    <div class="appointments-list-content">
                        <h3 class="appointments-title">NADCHODZĄCE WIZYTY</h3>
                        <div class="all-appointments-list">
                            @{
                                if (Model?.UpcomingBookings == null || !Model.UpcomingBookings.Any())
                                {
                                    <div class="all-appointment-item">Brak nadchodzących wizyt</div>
                                }
                                else
                                {
                                    var sortedBookings = Model.UpcomingBookings.OrderBy(b => b.Date + b.Time).ToList();
                                    foreach (var booking in sortedBookings)
                                    {
                                        var date = booking.Date;
                                        var month = date.ToString("MMM");
                                        var day = date.Day.ToString();
                                        var year = date.Year == DateTime.Now.Year ? "" : date.Year.ToString();
                                        var time = (booking.Date + booking.Time).ToString("HH:mm");
                                        <div class="all-appointment-item" data-booking-id="@booking.Id" data-date="@date.ToString("yyyy-MM-dd")" data-time="@time" data-service="@(booking.Service?.Name ?? "Brak nazwy")" data-price="@(booking.Service?.Price ?? 0)" data-duration="@(booking.Service?.DurationMinutes ?? 0)" data-employee-first-name="@(booking.Employee?.FirstName ?? "Brak pracownika")" data-employee-last-name="@(booking.Employee?.LastName ?? "")">
                                            <div class="date-details">
                                                <span class="date-detail month">@month</span>
                                                @if (!string.IsNullOrEmpty(year)) { <span class="date-detail year">@year</span> }
                                                <span class="date-detail day">@day</span>
                                                <span class="date-detail time">@time</span>
                                            </div>
                                            <div class="service-employee-name">
                                                <span class="service-name">@(booking.Service?.Name ?? "Brak nazwy")</span>
                                                <span class="employee-name">Pracownik: @(booking.Employee != null ? $"{booking.Employee.FirstName} {booking.Employee.LastName}" : "Brak pracownika")</span>
                                            </div>
                                            <button class="appointment-edit">ZARZĄDZAJ WIZYTĄ</button>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="appointment-management-container" id="appointment-management" style="display: none;">
                    <div class="appointment-management-content">
                        <div class="management-header">
                            <button class="go-back">←</button>
                            <div class="management-date-time">
                                <span id="management-time"></span>
                                <span id="management-date"></span>
                            </div>
                        </div>
                        <div class="management-details">
                            <div class="service-employee-name">
                                <span id="management-service"></span>
                                <span id="management-employee"></span>
                            </div>
                            <div class="management-price-time">
                                <div id="management-price"></div>
                                <div id="management-time-span"></div>
                            </div>
                        </div>
                        <div class="management-actions">
                            <button class="cancel-appointment">ANULUJ</button>
                            <button class="edit-appointment">EDYTUJ</button>
                        </div>
                    </div>
                </div>        
            </div>
            <div class="section-content" id="history" style="display: none;">
                <div class="past-appointments-container">
                    <div class="past-appointments-content">
                        <h3 class="appointments-title">ZAKOŃCZONE WIZYTY</h3>
                        <div class="all-appointments-list">
                            @{
                                if (Model?.PastBookings == null || !Model.PastBookings.Any()) {
                                    <div class="all-appointment-item">Brak zakończonych wizyt</div>
                                }
                                else {
                                    var sortedBookings = Model.PastBookings.OrderBy(b => b.Date + b.Time).ToList();
                                    foreach (var booking in sortedBookings)
                                    {
                                        var date = booking.Date;
                                        var month = date.ToString("MMM");
                                        var day = date.Day.ToString();
                                        var year = date.Year == DateTime.Now.Year ? "" : date.Year.ToString();
                                        var time = (booking.Date + booking.Time).ToString("HH:mm");
                                        <div class="all-appointment-item" data-service-id="@booking.ServiceId">
                                            <div class="date-details">
                                                <span class="date-detail month">@month</span>
                                                @if (!string.IsNullOrEmpty(year)) { <span class="date-detail year">@year</span> }
                                                <span class="date-detail day">@day</span>
                                                <span class="date-detail time">@time</span>
                                            </div>
                                            <span class="service-name">@(booking.Service?.Name ?? "Brak nazwy")</span>
                                            <button class="service-book-again">UMÓW PONOWNIE</button>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<footer class="footer">
    <div class="author">
        <p>ABOUT AUTHOR</p>
        <span class="tooltip">Kinga Kinowska</span>
    </div>
</footer>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            function updateView() {
                const hash = window.location.hash || '#dashboard';
                document.querySelectorAll('.section-content').forEach(section => {
                    section.style.display = 'none';
                });
                const section = document.getElementById(hash.substring(1));
                if (section) {
                    section.style.display = 'block';
                    if (hash === '#appointments') {
                        renderCalendar();
                    }
                }
            }

            const editButton = document.getElementById('edit-profile-btn');
            const saveButton = document.getElementById('save-profile-btn');
            const cancelButton = document.getElementById('cancel-changes-profile-btn');
            const profileForm = document.getElementById('profile-form');
            const inputs = document.querySelectorAll('#profile-form .edit-input');

            if (editButton) {
                editButton.addEventListener('click', () => {
                    inputs.forEach(input => {
                        input.removeAttribute('readonly');
                        input.style.backgroundColor = '#f9f9f9';
                    });
                    editButton.style.display = 'none';
                    if (cancelButton) cancelButton.style.display = 'inline-block';
                    if (saveButton) saveButton.style.display = 'inline-block';
                });
            }

            if (cancelButton) {
                cancelButton.addEventListener('click', () => {
                    inputs.forEach(input => {
                        input.setAttribute('readonly', 'true');
                        input.value = input.getAttribute('value') || '';
                        input.style.backgroundColor = 'transparent';
                    });
                    editButton.style.display = 'inline-block';
                    cancelButton.style.display = 'none';
                    saveButton.style.display = 'none';
                });
            }

            if (profileForm) 
            {
                profileForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(profileForm);
                    const profileData = {
                        FirstName: formData.get('Profile.FirstName')?.trim(),
                        LastName: formData.get('Profile.LastName')?.trim(),
                        PhoneNumber: formData.get('Profile.PhoneNumber')?.trim(),
                        Email: formData.get('Profile.Email')?.trim()
                    };

                    let isValid = true;
                    const requiredFields = {
                        'FirstName': 'Imię',
                        'LastName': 'Nazwisko',
                        'PhoneNumber': 'Numer telefonu',
                        'Email': 'Email'
                    };
                    for (const [key, label] of Object.entries(requiredFields)) {
                        if (!profileData[key]) {
                            isValid = false;
                            alert(`Pole ${label} jest wymagane.`);
                        }
                    }
                    if (!isValid) return;

                    try {
                        const response = await fetch('/MyAccount?handler=UpdateProfile', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': formData.get('__RequestVerificationToken')
                            },
                            body: JSON.stringify(profileData)
                        });

                        if (!response.ok) {
                            const errorText = await response.text();
                            let errorData;
                            try {
                                errorData = JSON.parse(errorText);
                            } catch {
                                errorData = { error: `Błąd HTTP: ${response.status}` };
                            }
                            const errorMessage = errorData.error || 'Nieznany błąd';
                            const details = errorData.details ? errorData.details.join(', ') : '';
                            alert(`Błąd podczas aktualizacji profilu: ${errorMessage}${details ? ': ' + details : ''}`);
                            return;
                        }

                        const result = await response.json();
                        if (result.success) {
                            inputs.forEach(input => {
                                input.setAttribute('readonly', 'true');
                                input.setAttribute('value', input.value);
                                input.style.backgroundColor = 'transparent';
                            });
                            editButton.style.display = 'inline-block';
                            saveButton.style.display = 'none';
                            cancelButton.style.display = 'none';
                            alert('Profil został zaktualizowany!');
                            window.location.reload();
                        } else {
                            alert(`Błąd podczas aktualizacji profilu: ${result.error || 'Nieznany błąd'}${result.details ? ': ' + result.details.join(', ') : ''}`);
                        }
                    } catch (error) {
                        alert('Wystąpił błąd podczas zapisywania zmian: ' + error.message);
                    }
                });
            }

            const passwordForm = document.getElementById('password-reset-form');
            if (passwordForm) {
                passwordForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(passwordForm);
                    const passwordData = {
                        Username: formData.get('Input.Username'),
                        OldPassword: formData.get('Input.OldPassword'),
                        NewPassword: formData.get('Input.NewPassword'),
                        ConfirmNewPassword: formData.get('Input.ConfirmNewPassword'),
                        __RequestVerificationToken: formData.get('__RequestVerificationToken')
                    };

                    try {
                        const response = await fetch('/MyAccount?handler=UpdatePassword', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': passwordData.__RequestVerificationToken
                            },
                            body: JSON.stringify(passwordData)
                        });

                        if (!response.ok) {
                            const errorText = await response.text();
                            let errorData;
                            try {
                                errorData = JSON.parse(errorText);
                            } catch {
                                errorData = { error: `Błąd HTTP: ${response.status}` };
                            }
                            throw new Error(errorData.error || 'Nieznany błąd');
                        }

                        const result = await response.json();
                        if (result.success) {
                            alert('Hasło zostało poprawnie zmienione');
                            window.location.href = '/MyAccount';
                        } else {
                            alert(result.error || 'Nieznany błąd podczas zmiany hasła.');
                        }
                    } catch (error) {
                        alert('Błąd podczas zmiany hasła: ' + error.message);
                    }
                });
            }

            const prevYear = document.getElementById('prev-year');
            const nextYear = document.getElementById('next-year');
            const yearDisplay = document.getElementById('year-display');
            const calendarGrid = document.getElementById('calendar-grid');
            const monthsRow = document.getElementById('months-row');
            const calendarDate = document.getElementById('calendar-date');
            const calendarDay = document.getElementById('calendar-day');
            const appointmentsList = document.getElementById('appointments-list');
            let currentDate = new Date();
            let selectedDateForAppointments = new Date();
            const allBookings = @Html.Raw(Json.Serialize(ViewData["AllBookings"] ?? new List<object>())) || [];

            function formatDateToYMD(date) {
                return date.toLocaleDateString('en-CA');
            }

            function renderCalendar() {
                if (yearDisplay) yearDisplay.textContent = currentDate.toLocaleString('pl-PL', { year: 'numeric' });
                if (calendarDate) calendarDate.textContent = selectedDateForAppointments.getDate();
                if (calendarDay) calendarDay.textContent = selectedDateForAppointments.toLocaleString('default', { month: 'short' });

                if (calendarGrid) {
                    while (calendarGrid.children.length > 7) {
                        if (calendarGrid.lastChild) calendarGrid.removeChild(calendarGrid.lastChild);
                    }
                }
                if (monthsRow) {
                    monthsRow.innerHTML = '';
                    const months = ['Styczeń', 'Luty', 'Marzec', 'Kwiecień', 'Maj', 'Czerwiec', 'Lipiec', 'Sierpień', 'Wrzesień', 'Październik', 'Listopad', 'Grudzień'];
                    months.forEach((month, index) => {
                        const monthElement = document.createElement('span');
                        monthElement.textContent = month.substring(0, 3);
                        monthElement.className = 'month-item';
                        if (index === currentDate.getMonth()) {
                            monthElement.style.fontFamily = 'Montserrat-Black';
                            monthElement.style.color = '#232323';
                            monthElement.style.fontSize = '0.9rem';
                        }
                        monthElement.addEventListener('click', () => {
                            currentDate.setMonth(index);
                            renderCalendar();
                        });
                        monthsRow.appendChild(monthElement);
                    });
                }

                const firstDay = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
                const daysInMonth = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 0).getDate();
                const firstDayIndex = (firstDay.getDay() + 6) % 7;

                if (calendarGrid) {
                    for (let i = 0; i < firstDayIndex; i++) {
                        const emptyDiv = document.createElement('div');
                        emptyDiv.className = 'calendar-day empty';
                        calendarGrid.appendChild(emptyDiv);
                    }

                    const today = new Date();
                    today.setHours(0, 0, 0, 0);
                    const todayStr = formatDateToYMD(today);

                    for (let day = 1; day <= daysInMonth; day++) {
                        const fullDate = new Date(currentDate.getFullYear(), currentDate.getMonth(), day);
                        const dayElement = document.createElement('div');
                        dayElement.style.display = 'flex';
                        dayElement.style.alignItems = 'center';
                        dayElement.style.justifyContent = 'center';
                        dayElement.style.width = '30px';
                        dayElement.style.height = '30px';
                        dayElement.style.cursor = 'pointer';
                        dayElement.textContent = day;
                        if (fullDate.toDateString() === today.toDateString()) {
                            dayElement.className = 'calendar-today';
                        } else if (fullDate < today) {
                            dayElement.className = 'calendar-day grey';
                            dayElement.style.pointerEvents = 'none';
                        } else {
                            dayElement.className = 'calendar-day';
                        }
                        const hasBooking = allBookings.some(b => b.date === formatDateToYMD(fullDate) && formatDateToYMD(fullDate) >= todayStr);
                        if (hasBooking) {
                            dayElement.style.border = '2px solid rgba(0, 0, 0, 0.6)';
                            dayElement.style.borderRadius = '50%';
                        }
                        dayElement.addEventListener('click', () => {
                            selectedDateForAppointments = new Date(currentDate.getFullYear(), currentDate.getMonth(), day);
                            if (calendarDate) calendarDate.textContent = selectedDateForAppointments.getDate();
                            if (calendarDay) calendarDay.textContent = selectedDateForAppointments.toLocaleString('default', { month: 'short' });
                            renderCalendar();
                            renderAppointments();
                        });
                        calendarGrid.appendChild(dayElement);
                    }
                }

                renderAppointments();
            }

            function renderAppointments() {
                if (appointmentsList) {
                    appointmentsList.innerHTML = '';
                    const selectedDate = formatDateToYMD(selectedDateForAppointments);
                    const appointments = allBookings
                        .filter(b => b.date === selectedDate)
                        .map(b => ({
                            id: b.id,
                            date: b.date,
                            time: b.time,
                            name: b.serviceName ?? 'Brak nazwy',
                            price: b.price ?? 0,
                            durationMinutes: b.durationMinutes ?? 0,
                            employeeFirstName: b.employeeFirstName ?? 'Brak pracownika',
                            employeeLastName: b.employeeLastName ?? '',
                            fullDate: new Date(`${b.date}T${b.time}`)
                        }))
                        .filter(b => !isNaN(b.fullDate.getTime()))
                        .sort((a, b) => a.fullDate - b.fullDate);

                    if (appointments.length > 0) {
                        appointments.forEach(b => {
                            const appointmentItem = document.createElement('div');
                            appointmentItem.className = 'appointment-item';
                            appointmentItem.setAttribute('data-booking-id', b.id);
                            appointmentItem.setAttribute('data-date', b.date);
                            appointmentItem.setAttribute('data-time', b.time);
                            appointmentItem.setAttribute('data-service', b.name);
                            appointmentItem.setAttribute('data-price', b.price);
                            appointmentItem.setAttribute('data-duration', b.durationMinutes);
                            appointmentItem.setAttribute('data-employee-first-name', b.employeeFirstName);
                            appointmentItem.setAttribute('data-employee-last-name', b.employeeLastName);
                            appointmentItem.innerHTML = `<span style="font-size: 0.8rem; margin-right: 5px; font-family:'Montserrat-Black';">${b.fullDate.toLocaleString('pl-PL', { hour: '2-digit', minute: '2-digit' })}</span><span>${b.name}</span><span style="font-size: 0.6rem; color: #606060; display: block;">Pracownik: ${b.employeeFirstName} ${b.employeeLastName}</span>`;
                            appointmentItem.addEventListener('click', () => showAppointmentManagement(b));
                            appointmentsList.appendChild(appointmentItem);
                        });
                    } else {
                        const noAppointments = document.createElement('div');
                        noAppointments.className = 'appointment-item';
                        noAppointments.textContent = 'Brak wizyt na dany dzień';
                        appointmentsList.appendChild(noAppointments);
                    }
                }
            }

            function showAppointmentManagement(booking) {
                const management = document.getElementById('appointment-management');
                if (management) {
                    const managementService = document.getElementById('management-service');
                    const managementEmployee = document.getElementById('management-employee');
                    const managementTime = document.getElementById('management-time');
                    const managementDate = document.getElementById('management-date');
                    const managementPrice = document.getElementById('management-price');
                    const managementTimeSpan = document.getElementById('management-time-span');

                    if (managementService) managementService.textContent = booking.name;
                    if (managementEmployee) managementEmployee.textContent = `Pracownik: ${booking.employeeFirstName} ${booking.employeeLastName}`;
                    if (managementTime) managementTime.textContent = booking.time;
                    if (managementDate) {
                        const date = new Date(booking.date);
                        const days = ['nie', 'pon', 'wto', 'śro', 'czw', 'pią', 'sob'];
                        const dayOfWeek = days[date.getDay()];
                        const day = date.getDate();
                        const months = ['sty', 'lut', 'mar', 'kwi', 'maj', 'czer', 'lip', 'sie', 'wrze', 'paź', 'lis', 'gru'];
                        const month = months[date.getMonth()];
                        managementDate.textContent = `⋅ ${dayOfWeek}, ${day} ${month}`;
                    }
                    if (managementPrice) managementPrice.textContent = `${(booking.price ?? 0).toFixed(2)} zł`;
                    if (managementTimeSpan) {
                        const startTime = new Date(`${booking.date}T${booking.time}`);
                        const endTime = new Date(startTime.getTime() + (booking.durationMinutes ?? 0) * 60000);
                        managementTimeSpan.textContent = `${startTime.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' })} - ${endTime.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' })}`;
                    }
                    management.setAttribute('data-booking-id', booking.id);
                    management.style.display = 'block';
                    const calendarView = document.getElementById('calendar-view');
                    const listView = document.getElementById('list-view');
                    const toggle = document.getElementById('toggle');
                    if (calendarView) calendarView.style.display = 'none';
                    if (listView) listView.style.display = 'none';
                    if (toggle) toggle.style.display = 'none';
                }
            }

            if (calendarGrid && calendarGrid.children.length === 0) {
                const days = ['Pon', 'Wt', 'Śr', 'Czw', 'Pt', 'So', 'Nd'];
                days.forEach(day => {
                    const dayElement = document.createElement('div');
                    dayElement.className = 'calendar-weekday';
                    dayElement.textContent = day;
                    dayElement.style.fontWeight = 'bold';
                    dayElement.style.color = '#777777';
                    calendarGrid.appendChild(dayElement);
                });
            }

            renderCalendar();

            if (prevYear) {
                prevYear.addEventListener('click', () => {
                    currentDate.setFullYear(currentDate.getFullYear() - 1);
                    renderCalendar();
                });
            }

            if (nextYear) {
                nextYear.addEventListener('click', () => {
                    currentDate.setFullYear(currentDate.getFullYear() + 1);
                    renderCalendar();
                });
            }

            const addEvent = document.getElementById('add-event');
            if (addEvent) {
                addEvent.addEventListener('click', () => {
                    alert('Dodaj nową wizytę (funkcja do zaimplementowania).');
                });
            }

            const calendarToggle = document.getElementById('calendar-toggle');
            const listToggle = document.getElementById('list-toggle');
            const calendarView = document.getElementById('calendar-view');
            const listView = document.getElementById('list-view');

            if (calendarToggle) {
                calendarToggle.addEventListener('click', () => {
                    if (calendarToggle && listToggle && calendarView && listView) {
                        calendarToggle.classList.add('active');
                        listToggle.classList.remove('active');
                        calendarView.style.display = 'block';
                        listView.style.display = 'none';
                        const management = document.getElementById('appointment-management');
                        if (management && management.style.display === 'block') {
                            showAppointmentManagement({
                                id: management.getAttribute('data-booking-id'),
                                date: document.getElementById('management-date')?.textContent,
                                time: document.getElementById('management-time')?.textContent,
                                name: document.getElementById('management-service')?.textContent,
                                employeeFirstName: document.getElementById('management-employee')?.textContent.split(' ')[0] || 'Brak pracownika',
                                employeeLastName: document.getElementById('management-employee')?.textContent.split(' ')[1] || ''
                            });
                        }
                    }
                });
            }

            if (listToggle) {
                listToggle.addEventListener('click', () => {
                    if (calendarToggle && listToggle && calendarView && listView) {
                        listToggle.classList.add('active');
                        calendarToggle.classList.remove('active');
                        calendarView.style.display = 'none';
                        listView.style.display = 'block';
                        const management = document.getElementById('appointment-management');
                        if (management && management.style.display === 'block') {
                            showAppointmentManagement({
                                id: management.getAttribute('data-booking-id'),
                                date: document.getElementById('management-date')?.textContent,
                                time: document.getElementById('management-time')?.textContent,
                                name: document.getElementById('management-service')?.textContent,
                                employeeFirstName: document.getElementById('management-employee')?.textContent.split(' ')[0] || 'Brak pracownika',
                                employeeLastName: document.getElementById('management-employee')?.textContent.split(' ')[1] || ''
                            });
                        }
                    }
                });
            }

            document.querySelectorAll('.appointment-edit').forEach(button => {
                if (button) {
                    button.addEventListener('click', (e) => {
                        e.preventDefault();
                        const item = button.parentElement;
                        const booking = {
                            id: item.getAttribute('data-booking-id'),
                            date: item.getAttribute('data-date'),
                            time: item.getAttribute('data-time'),
                            name: item.getAttribute('data-service'),
                            price: parseFloat(item.getAttribute('data-price') ?? '0'),
                            durationMinutes: parseInt(item.getAttribute('data-duration') ?? '0'),
                            employeeFirstName: item.getAttribute('data-employee-first-name') ?? 'Brak pracownika',
                            employeeLastName: item.getAttribute('data-employee-last-name') ?? ''
                        };
                        showAppointmentManagement(booking);
                    });
                }
            });

            const cancelAppointment = document.querySelector('.cancel-appointment');
            if (cancelAppointment) {
                cancelAppointment.addEventListener('click', () => {
                    const bookingId = document.getElementById('appointment-management')?.getAttribute('data-booking-id');
                    if (!bookingId) {
                        alert('Błąd: Nie można znaleźć ID rezerwacji.');
                        return;
                    }
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const formData = new FormData();
                    formData.append('bookingId', bookingId);
                    formData.append('__RequestVerificationToken', token);

                    fetch('/MyAccount?handler=CancelBooking', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) {
                            return response.text().then(text => { 
                                throw new Error(`HTTP error! status: ${response.status}, message: ${text}`); 
                            });
                        }
                        return response.json().then(data => ({ response, data }));
                    })
                    .then(({ response, data }) => {
                        if (data.success) {
                            window.location.hash = '#appointments';
                            location.reload();
                        } else {
                            alert(`Błąd podczas anulowania rezerwacji: ${data.error || 'Nieznany błąd'}`);
                        }
                    })
                    .catch(error => {
                        alert(`Błąd podczas anulowania rezerwacji: ${error.message}`);
                    });
                });
            }

            const editAppointment = document.querySelector('.edit-appointment');
            if (editAppointment) {
                editAppointment.addEventListener('click', () => {
                    const bookingId = document.getElementById('appointment-management')?.getAttribute('data-booking-id');
                    if (bookingId) {
                        window.location.href = `/AppointmentBooking?bookingId=${bookingId}`;
                    }
                });
            }

            const goBack = document.querySelector('.go-back');
            if (goBack) {
                goBack.addEventListener('click', () => {
                    const appointmentManagement = document.getElementById('appointment-management');
                    if (appointmentManagement) {
                        appointmentManagement.style.display = 'none';
                    }
                    const toggle = document.getElementById('toggle');
                    if (toggle) toggle.style.display = 'flex';
                    if (listToggle && listToggle.className === 'toggle-button active') {
                        if (listView) listView.style.display = 'block';
                    } else {
                        if (calendarView) calendarView.style.display = 'block';
                    }
                });
            }

            document.querySelectorAll('.service-book-again').forEach(button => {
                if (button) {
                    button.addEventListener('click', (e) => {
                        e.preventDefault();
                        const item = button.parentElement;
                        const serviceId = item.getAttribute('data-service-id');
                        if (serviceId) {
                            window.location.href = `/AppointmentBooking?serviceId=${serviceId}`;
                        }
                    });
                }
            });

            window.addEventListener('popstate', () => {
                updateView();
            });

            window.addEventListener('load', () => {
                updateView();
                if (calendarDate) calendarDate.textContent = selectedDateForAppointments.getDate();
                if (calendarDay) calendarDay.textContent = selectedDateForAppointments.toLocaleString('default', { month: 'short' });
            });
        });
    </script>
}

