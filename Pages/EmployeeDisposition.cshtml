        height: 100vh;
        background: linear-gradient(135deg, #e0f7fa, #c1e1ec);
        background-image: url('/images/sign_in_up_background2.png');
        background-repeat: no-repeat;
        background-position: center center;
        background-size: cover;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        margin: 0;
        padding: 0;
        font-family: 'Montserrat', sans-serif;
    }

    .employee-disposition-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        height: 93.5vh;
        overflow: hidden;
    }

    .custom-header {
        padding: 10px;
        height: 55px;
        border-bottom: 2px solid #000;
        background-color: #fff;
        position: relative;
    }

    .navbar {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    .nav-item {
        display: flex;
        align-items: center;
        margin-top: 3.5px;
    }

    .nav-item.center {
        display: flex;
        align-items: center;
    }

    .nav-logo {
        height: 28px;
        width: auto;
    }

    .nav-item.right {
        position: absolute;
        right: 10px;
        display: flex;
        align-items: center;
    }

    .nav-calendar {
        width: 26px;
        height: 26px;
        margin-right: 35px;
    }

    .nav-calendar:hover {
        opacity: 0.75;
        transition: transform 0.5s ease;
    }

    .nav-icon {
        width: 26px;
        height: 26px;
        margin: 0 10px 2px 0;
    }

    .dropdown {
        position: relative;
        display: inline-block;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        right: -20px;
        color: #000;
        min-width: 150px;
