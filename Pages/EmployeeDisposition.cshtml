        padding: 10px 15px;
        text-decoration: none;
        display: block;
        line-height: 15px;
        font-size: 14px;
    }

    .nav-link.my-account {
        border-bottom: #606060 1px solid;
    }

    .sign.my-account {
        border-bottom: #606060 1px solid;
    }

    .sign:hover {
        font-weight: 900;
        transform: scale(1.1);
        animation: skew-x-shake 2s infinite;
    }

    .dropdown:hover .dropdown-menu {
        display: block;
    }

    @@keyframes skew-x-shake {
        0% { transform: skewX(-10deg); }
        5% { transform: skewX(10deg); }
        10% { transform: skewX(-10deg); }
        15% { transform: skewX(10deg); }
        20% { transform: skewX(0deg); }
        100% { transform: skewX(0deg); }
    }

    .footer {
        bottom: 0;
        z-index: 1000;
        min-height: 20px;
        padding: 0;
        display: block;
        position: relative;
        margin-top: 0;
        background-color: #fff;
        border-top: 2px solid #000;
    }

    .author {
        position: relative;
        top: 50%;
        text-align: center;
        width: 100%;
        padding: 10px 0;
    }

    .author p {
        margin: 0;
        font-size: 11px;
    }

    .tooltip {
        display: none;
        position: absolute;
        top: -50px;
        left: 50%;
        transform: translateX(-50%);
        background: #333;
        color: #fff;
        padding: 2.5px;
        border-radius: 3px;
        white-space: nowrap;
        z-index: 1001;
    }

    .author:hover .tooltip {
        display: block;
    }

    .disposition-content {
        flex: 1;
        padding: 20px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .welcome-title {
        font-family: 'Montserrat-Black';
