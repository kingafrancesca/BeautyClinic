@page "{id}"
@model BeautyClinic.Pages.EmployeeDispositionModel
@{
    ViewData["Title"] = "Dyspozycyjność pracownika";
}

<div class="employee-disposition-container">
    <header class="custom-header">
        <div class="navbar">
            <div class="nav-item center" style="font-family:'Montserrat-Light'">
                <a class="nav-link" asp-page="/CompanyView">
                    <img src="~/images/logo-company.png" alt="BEAUTY CLINIC dla firm" class="nav-logo">
                </a>
            </div>
            <div class="nav-item right">
                <div class="dropdown">
                    <span style="cursor: pointer;">
                        <img src="~/images/user.png" alt="Moje konto" class="nav-icon">
                    </span>
                    <div class="dropdown-menu">
                        <a class="sign my-account" href="/EmployeeAccount">Moje konto</a>
                        <a class="sign sign-out" href="/Logout">Wyloguj</a>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <div class="disposition-content">
        <h2 class="welcome-title">TWOJA DYSPOZYCYJNOŚĆ</h2>
        <div class="calendar-container">
            <div class="calendar-base">
                <div class="calendar-right">
                    <div class="month-nav">
                        <span class="nav-arrow" id="prev-month">←</span>
                        <span class="month-display" id="month-display"></span>
                        <span class="nav-arrow" id="next-month">→</span>
                    </div>
                    <div class="calendar-grid" id="calendar-grid"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal" id="disposition-modal" style="display: none;">
        <div class="modal-content">
            <div id="modal-date-info" style="font-family: 'Montserrat-Bold'; font-size: 1.1rem; margin: 10px 0 20px 0; text-align: left;"></div>
            <form id="disposition-form" method="post" asp-page-handler="SaveDisposition">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Input.Date" id="modal-date" />
                <div class="form-group">
                    <label for="start-time">Godzina rozpoczęcia:</label>
                    <select asp-for="Input.StartTime" id="start-time" class="form-control">
                        <option value="">Wybierz godzinę</option>
                        @for (int hour = 10; hour <= 15; hour++)
                        {
                            <option value="@(new TimeSpan(hour, 0, 0))">@hour:00</option>
                        }
                    </select>
                    <span asp-validation-for="Input.StartTime" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label for="end-time">Godzina zakończenia:</label>
                    <select asp-for="Input.EndTime" id="end-time" class="form-control">
                        <option value="">Wybierz godzinę</option>
                        @for (int hour = 11; hour <= 16; hour++)
                        {
                            <option value="@(new TimeSpan(hour, 0, 0))">@hour:00</option>
                        }
                    </select>
                    <span asp-validation-for="Input.EndTime" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>
                        <input type="checkbox" asp-for="Input.IsUnavailable" id="is-unavailable" />
                        Niedostępny
                    </label>
                    <span asp-validation-for="Input.IsUnavailable" class="text-danger"></span>
                </div>
                <button type="submit" class="save-button">Zapisz zmiany</button>
                <button type="button" class="cancel-button" id="cancel-modal">Anuluj</button>
                <div id="form-error" class="text-danger" style="display: none;"></div>
            </form>
        </div>
    </div>
</div>
<footer class="footer">
    <div class="author">
        <p>ABOUT AUTHOR</p>
        <span class="tooltip">Kinga Kinowska</span>
    </div>
</footer>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const prevMonth = document.getElementById('prev-month');
            const nextMonth = document.getElementById('next-month');
            const monthDisplay = document.getElementById('month-display');
            const calendarGrid = document.getElementById('calendar-grid');
            const modal = document.getElementById('disposition-modal');
            const cancelModal = document.getElementById('cancel-modal');
            const dispositionForm = document.getElementById('disposition-form');
            const startTimeSelect = document.getElementById('start-time');
            const endTimeSelect = document.getElementById('end-time');
            const isUnavailableCheckbox = document.getElementById('is-unavailable');
            const formError = document.getElementById('form-error');
            const modalDateInfo = document.getElementById('modal-date-info');
            let currentDate = new Date();
            const employeeId = '@Model.Employee?.Id';

            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const minDate = new Date(today);
            minDate.setDate(today.getDate() + 1);
            const maxDate = new Date(today);
            maxDate.setMonth(today.getMonth() + 2);

            function formatDateToYMD(date) {
                return date.toLocaleDateString('en-CA');
            }

            function getMonthYearDisplay(date) {
                const months = ['styczeń', 'luty', 'marzec', 'kwiecień', 'maj', 'czerwiec', 'lipiec', 'sierpień', 'wrzesień', 'październik', 'listopad', 'grudzień'];
                return `${months[date.getMonth()]} ${date.getFullYear()}`;
            }

            async function fetchDispositions(month, year) {
                const response = await fetch(`/EmployeeDisposition/${employeeId}?handler=GetDispositions&month=${month}&year=${year}`, {
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });
                if (!response.ok) throw new Error('Błąd pobierania dyspozycji');
                return response.json();
            }

            async function renderCalendar() {
                if (monthDisplay) monthDisplay.textContent = getMonthYearDisplay(currentDate);

                if (calendarGrid) {
                    calendarGrid.innerHTML = '';
                    const days = ['Pon', 'Wt', 'Śr', 'Czw', 'Pt', 'So', 'Nd'];
                    days.forEach(day => {
                        const dayElement = document.createElement('div');
                        dayElement.className = 'calendar-weekday';
                        dayElement.textContent = day;
                        dayElement.style.fontWeight = 'bold';
                        dayElement.style.color = '#787878';
                        dayElement.style.width = '75px';
                        dayElement.style.marginBottom = '5px';
                        calendarGrid.appendChild(dayElement);
                    });

                    const firstDay = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
                    const daysInMonth = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 0).getDate();
                    const firstDayIndex = (firstDay.getDay() + 6) % 7;

                    for (let i = 0; i < firstDayIndex; i++) {
                        const emptyDiv = document.createElement('div');
                        emptyDiv.className = 'calendar-day empty';
                        calendarGrid.appendChild(emptyDiv);
                    }

                    const dispositions = await fetchDispositions(currentDate.getMonth() + 1, currentDate.getFullYear());
                    console.log('Fetched dispositions for month/year:', currentDate.getMonth() + 1, currentDate.getFullYear(), dispositions);

                    const todayStr = formatDateToYMD(today);

                    for (let day = 1; day <= daysInMonth; day++) {
                        const fullDate = new Date(currentDate.getFullYear(), currentDate.getMonth(), day);
                        const dayElement = document.createElement('div');
                        dayElement.style.display = 'flex';
                        dayElement.style.alignItems = 'center';
                        dayElement.style.justifyContent = 'center';
                        dayElement.style.width = '72.5px';
                        dayElement.style.height = '32.5px';
                        dayElement.style.cursor = 'pointer';
                        dayElement.textContent = day;

                        const calendarDate = formatDateToYMD(fullDate);
                        const disposition = dispositions.find(d => d.date === calendarDate);
                        if (disposition) {
                            dayElement.style.borderRadius = '10px';
                            if (disposition.isUnavailable) {
                                dayElement.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';
                            } else {
                                dayElement.style.backgroundColor = 'rgba(0, 255, 0, 0.3)';
                            }
                        }

                        if (fullDate.toDateString() === today.toDateString()) {
                            dayElement.className = 'calendar-today';
                        } else if (fullDate < minDate || fullDate > maxDate) {
                            dayElement.className = 'calendar-day grey';
                            dayElement.style.pointerEvents = 'none';
                        } else if (fullDate < today) {
                            dayElement.className = 'calendar-day grey';
                            dayElement.style.pointerEvents = 'none';
                        } else {
                            dayElement.className = 'calendar-day';
                        }

                        dayElement.addEventListener('click', () => {
                            console.log(`Click on ${formatDateToYMD(fullDate)}, minDate: ${formatDateToYMD(minDate)}, maxDate: ${formatDateToYMD(maxDate)}`);
                            if (fullDate >= minDate && fullDate <= maxDate) {
                                const dateStr = formatDateToYMD(fullDate);
                                const dayName = ['Niedziela', 'Poniedziałek', 'Wtorek', 'Środa', 'Czwartek', 'Piątek', 'Sobota'][fullDate.getDay()];
                                document.getElementById('modal-date').value = dateStr;
                                modalDateInfo.textContent = `${dayName}, ${fullDate.toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}`
                                const existingDisposition = dispositions.find(d => d.date === dateStr);
                                startTimeSelect.value = existingDisposition?.startTime || '';
                                endTimeSelect.value = existingDisposition?.endTime || '';
                                isUnavailableCheckbox.checked = existingDisposition?.isUnavailable || false;
                                updateSelectState();
                                modal.style.display = 'flex';
                                console.log(`Clicked date: ${dateStr}, Disposition:`, existingDisposition);
                            } else {
                                console.log(`Date ${formatDateToYMD(fullDate)} is outside min/max range`);
                            }
                        });
                        calendarGrid.appendChild(dayElement);
                    }
                }
            }

            function updateSelectState() {
                const disabled = isUnavailableCheckbox.checked;
                startTimeSelect.disabled = disabled;
                endTimeSelect.disabled = disabled;
                if (disabled) {
                    startTimeSelect.value = '';
                    endTimeSelect.value = '';
                }
                formError.style.display = 'none';
                formError.textContent = '';
            }

            if (isUnavailableCheckbox) {
                isUnavailableCheckbox.addEventListener('change', updateSelectState);
            }

            if (cancelModal) {
                cancelModal.addEventListener('click', () => {
                    modal.style.display = 'none';
                    formError.style.display = 'none';
                    dispositionForm.reset();
                });
            }

            if (dispositionForm) {
                dispositionForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(dispositionForm);
                    const isUnavailable = formData.get('Input.IsUnavailable') === 'true' || formData.get('Input.IsUnavailable') === 'on';
                    let startTime = formData.get('Input.StartTime');
                    let endTime = formData.get('Input.EndTime');

                    console.log('Form Data:', {
                        Date: formData.get('Input.Date'),
                        StartTime: startTime,
                        EndTime: endTime,
                        IsUnavailable: isUnavailable
                    });

                    if (!isUnavailable && (!startTime || !endTime)) {
                        formError.style.display = 'block';
                        formError.textContent = 'Godziny rozpoczęcia i zakończenia są wymagane, jeśli pracownik jest dostępny.';
                        return;
                    }

                    const dispositionData = {
                        Date: formData.get('Input.Date'),
                        StartTime: startTime || null,
                        EndTime: endTime || null,
                        IsUnavailable: isUnavailable
                    };

                    try {
                        const response = await fetch(`/EmployeeDisposition/${employeeId}?handler=SaveDisposition`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': formData.get('__RequestVerificationToken')
                            },
                            body: JSON.stringify(dispositionData)
                        });

                        if (!response.ok) {
                            const errorText = await response.text();
                            console.error(`[${new Date().toLocaleString('pl-PL')}] Błąd serwera: ${response.status} ${errorText}`);
                            let errorData;
                            try {
                                errorData = JSON.parse(errorText);
                            } catch {
                                errorData = { error: `Błąd HTTP: ${response.status}` };
                            }
                            formError.style.display = 'block';
                            formError.textContent = `Błąd: ${errorData.error}${errorData.details ? ': ' + errorData.details : ''}`;
                            return;
                        }

                        const result = await response.json();
                        if (result.success) {
                            modal.style.display = 'none';
                            alert(result.message || 'Dyspozycja zapisana!');
                            window.location.reload();
                        } else {
                            formError.style.display = 'block';
                            formError.textContent = `Błąd: ${result.error}${result.details ? ': ' + result.details : ''}`;
                        }
                    } catch (error) {
                        console.error(`[${new Date().toLocaleString('pl-PL')}] Błąd fetch: ${error}`);
                        formError.style.display = 'block';
                        formError.textContent = 'Wystąpił błąd podczas zapisywania zmian: ' + error.message;
                    }
                });
            }

            if (prevMonth) {
                prevMonth.addEventListener('click', () => {
                    currentDate.setMonth(currentDate.getMonth() - 1);
                    renderCalendar();
                });
            }

            if (nextMonth) {
                nextMonth.addEventListener('click', () => {
                    currentDate.setMonth(currentDate.getMonth() + 1);
                    renderCalendar();
                });
            }

            renderCalendar();
        });
    </script>
}

<style>
